# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT — generate a strong random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Bunny.net
BUNNY_API_KEY=your-bunny-api-key
BUNNY_STORAGE_ZONE=cloud-elevate
BUNNY_CDN_HOSTNAME=https://cloud-elevate.b-cdn.net
BUNNY_LIBRARY_ID=your-stream-library-id
BUNNY_STREAM_API_KEY=your-stream-api-key

# IP Geolocation (free at ip-api.com — no key needed)
IP_API_URL=http://ip-api.com/json

# Admin
ADMIN_EMAIL=your-admin-email@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
